# ============================================================
# Variables de entorno para monitor-gen-resumen
# Conexion a Oracle Autonomous DB via Wallet
# ============================================================
# Copiar este archivo como .env y completar los valores reales

# Ruta al directorio del Wallet (TNS_ADMIN)
ORACLE_WALLET_LOCATION=/ruta/al/Wallet_BDBUSESRED

# URL de conexion JDBC usando el TNS alias del wallet
SPRING_DATASOURCE_URL=jdbc:oracle:thin:@bdbusesred_medium?TNS_ADMIN=${ORACLE_WALLET_LOCATION}

# Credenciales de la base de datos Oracle
SPRING_DATASOURCE_USERNAME=ADMIN
SPRING_DATASOURCE_PASSWORD=

# Driver y dialecto
SPRING_DATASOURCE_DRIVER_CLASS_NAME=oracle.jdbc.OracleDriver
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.OracleDialect

# Hibernate DDL
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Kafka Bootstrap Servers
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:29092,localhost:39092,localhost:49092
